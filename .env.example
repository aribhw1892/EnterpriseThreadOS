# Local-only development defaults. Do not use these values in shared or production environments.

POSTGRES_DB=etos
POSTGRES_USER=etos
POSTGRES_PASSWORD=etos_dev_password
POSTGRES_PORT=5432

NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=etos_neo4j_dev_password

# Optional Memgraph evaluation profile only. Use
# `docker compose --profile memgraph-optional ...` to start it.
# MEMGRAPH_BOLT_PORT=7688
# MEMGRAPH_HTTP_PORT=7444

QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

MINIO_ROOT_USER=etosminio
MINIO_ROOT_PASSWORD=etos_minio_dev_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

REDIS_PORT=6379

RABBITMQ_DEFAULT_USER=etos
RABBITMQ_DEFAULT_PASS=etos_rabbit_dev_password
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

ETOS_BACKEND_URL=http://localhost:5000
NEXT_PUBLIC_ETOS_API_BASE_URL=http://localhost:5000
NEXT_PUBLIC_ETOS_ADMIN_USER_ID=11111111-1111-1111-1111-111111111111
NEXT_PUBLIC_ETOS_TENANT_ID=22222222-2222-2222-2222-222222222222
