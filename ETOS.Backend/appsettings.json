{
  "AllowedHosts": "*",
  "Frontend": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Infrastructure": {
    "ProbeTimeoutMilliseconds": 750,
    "PostgreSql": {
      "Name": "PostgreSQL",
      "Host": "localhost",
      "Port": 5432
    },
    "Neo4j": {
      "Name": "Neo4j",
      "Host": "localhost",
      "Port": 7687,
      "HealthUrl": "http://localhost:7474"
    },
    "Qdrant": {
      "Name": "Qdrant",
      "Host": "localhost",
      "Port": 6333,
      "HealthUrl": "http://localhost:6333/readyz"
    },
    "Minio": {
      "Name": "MinIO",
      "Host": "localhost",
      "Port": 9000,
      "HealthUrl": "http://localhost:9000/minio/health/ready"
    },
    "Redis": {
      "Name": "Redis",
      "Host": "localhost",
      "Port": 6379
    },
    "RabbitMq": {
      "Name": "RabbitMQ",
      "Host": "localhost",
      "Port": 5672
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OperationalStore": {
    "ConnectionString": "Host=localhost;Port=5432;Database=etos;Username=etos;Password=etos_dev_password"
  },
  "GraphMemory": {
    "Provider": "Neo4j",
    "Neo4j": {
      "Uri": "bolt://localhost:7687",
      "Username": "neo4j",
      "Password": "etos_neo4j_dev_password",
      "Database": "neo4j",
      "Enabled": true,
      "BootstrapOnStartup": true
    },
    "Memgraph": {
      "Enabled": false
    }
  }
}
